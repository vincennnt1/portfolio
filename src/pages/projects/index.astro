---
import Base from '../../layouts/Base.astro';
---

<Base title="Projects — Vincent Genov" description="Projects by Vincent Genov — data engineering, interactive visualization, and game development.">
  <div class="page">

    <h2 class="page-label">Projects</h2>

    <!-- ── Featured: Arms Trade ── -->
    <article class="feature">
      <div class="feature-meta">
        <span class="tag">Data Engineering</span>
        <span class="tag">Network Analysis</span>
        <span class="tag">React + D3</span>
        <span class="tag">Python</span>
      </div>
      <h1><a href="/projects/arms-trade">Global Arms Trade Network</a></h1>
      <p class="feature-desc">
        85 years of SIPRI arms-transfer data — 258 countries, 3,150 supplier→recipient
        flows, 497 anomaly spikes — built into an interactive world map. The project traces
        how Cold War alliances, proxy conflicts, and regime changes reshape who arms whom,
        and when.
      </p>
      <div class="feature-links">
        <a href="/projects/arms-trade">Read more →</a>
        <a href="https://github.com/vincennnt1/WatchTower" target="_blank" rel="noopener">GitHub</a>
      </div>
    </article>

    <hr class="divider" />

    <!-- ── Secondary: Bad Link ── -->
    <article class="secondary">
      <div class="secondary-header">
        <h3><a href="/projects/bad-link">Bad Link</a></h3>
        <div class="tags">
          <span class="tag">C++</span>
          <span class="tag">SFML</span>
          <span class="tag">Game Jam</span>
        </div>
      </div>
      <p class="secondary-desc">
        Two-player co-op puzzle game built from scratch (no engine) in 48 hours for
        Mini Jam 111. Theme: Colors. All physics, collision, and rendering written in C++ + SFML.
      </p>
      <div class="secondary-links">
        <a href="/projects/bad-link">Read more →</a>
        <a href="https://vincennnt1.itch.io/bad-link" target="_blank" rel="noopener">Play on Itch.io</a>
        <a href="https://github.com/vincennnt1" target="_blank" rel="noopener">GitHub</a>
      </div>
    </article>

  </div>
</Base>

<style>
  .page-label {
    margin-bottom: 3rem;
  }

  /* ── Feature block ── */

  .feature {
    margin-bottom: 3rem;
  }

  .feature-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .feature h1 {
    font-size: clamp(1.9rem, 4vw, 2.6rem);
    margin-bottom: 1rem;
  }

  .feature h1 a {
    color: var(--text);
    border-bottom: none;
    transition: color 0.15s;
  }

  .feature h1 a:hover {
    color: var(--accent);
  }

  .feature-desc {
    font-size: 1rem;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .feature-links {
    display: flex;
    gap: 1.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    letter-spacing: 0.03em;
  }

  .feature-links a {
    color: var(--muted);
    border-bottom: none;
    transition: color 0.15s;
  }

  .feature-links a:first-child {
    color: var(--accent);
  }

  .feature-links a:hover {
    color: var(--text);
  }

  /* ── Divider ── */

  .divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  /* ── Secondary block ── */

  .secondary-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .secondary h3 a {
    color: var(--text);
    border-bottom: none;
    transition: color 0.15s;
  }

  .secondary h3 a:hover {
    color: var(--accent);
  }

  .secondary-desc {
    font-size: 0.975rem;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .secondary-links {
    display: flex;
    gap: 1.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.03em;
  }

  .secondary-links a {
    color: var(--muted);
    border-bottom: none;
    transition: color 0.15s;
  }

  .secondary-links a:first-child {
    color: var(--accent);
  }

  .secondary-links a:hover {
    color: var(--text);
  }
</style>
